<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/ontology/bookrec#"
     xml:base="http://example.org/ontology/bookrec"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:bookrec="http://example.org/ontology/bookrec#">

    <owl:Ontology rdf:about="http://example.org/ontology/bookrec">
        <rdfs:label>Book Recommendation Ontology</rdfs:label>
        <rdfs:comment>An ontology for a book recommendation system based on user preferences and reading levels.</rdfs:comment>
    </owl:Ontology>

    <!-- CLASSES -->
    <owl:Class rdf:about="http://example.org/ontology/bookrec#Book">
        <rdfs:label>Book</rdfs:label>
        <rdfs:comment>A book that can be recommended to users.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/bookrec#User">
        <rdfs:label>User</rdfs:label>
        <rdfs:comment>A user of the book recommendation system.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/bookrec#Theme">
        <rdfs:label>Theme</rdfs:label>
        <rdfs:comment>A genre or theme that a book can belong to.</rdfs:comment>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/bookrec#ReadingLevel">
        <rdfs:label>Reading Level</rdfs:label>
        <rdfs:comment>The difficulty level of a book or the reading proficiency of a user.</rdfs:comment>
    </owl:Class>

    <!-- OBJECT PROPERTIES -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/bookrec#hasTheme">
        <rdfs:label>has theme</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/bookrec#Book"/>
        <rdfs:range rdf:resource="http://example.org/ontology/bookrec#Theme"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/bookrec#hasReadingLevel">
        <rdfs:label>has reading level</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/bookrec#Book"/>
        <rdfs:range rdf:resource="http://example.org/ontology/bookrec#ReadingLevel"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/bookrec#userHasReadingLevel">
        <rdfs:label>user has reading level</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/bookrec#User"/>
        <rdfs:range rdf:resource="http://example.org/ontology/bookrec#ReadingLevel"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/bookrec#prefersTheme">
        <rdfs:label>prefers theme</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/bookrec#User"/>
        <rdfs:range rdf:resource="http://example.org/ontology/bookrec#Theme"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/bookrec#isRecommendedFor">
        <rdfs:label>is recommended for</rdfs:label>
        <rdfs:comment>A book is recommended for a user if it matches both the user's preferred theme and reading level.</rdfs:comment>
        <rdfs:domain rdf:resource="http://example.org/ontology/bookrec#Book"/>
        <rdfs:range rdf:resource="http://example.org/ontology/bookrec#User"/>
    </owl:ObjectProperty>

    <!-- DATATYPE PROPERTIES -->
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/bookrec#hasAuthor">
        <rdfs:label>has author</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/bookrec#Book"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/bookrec#hasTitle">
        <rdfs:label>has title</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/bookrec#Book"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/bookrec#hasName">
        <rdfs:label>has name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/bookrec#User"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- INDIVIDUALS: THEMES -->
    <owl:NamedIndividual rdf:about="http://example.org/ontology/bookrec#ScienceFiction">
        <rdf:type rdf:resource="http://example.org/ontology/bookrec#Theme"/>
        <rdfs:label>Science Fiction</rdfs:label>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/ontology/bookrec#Fantasy">
        <rdf:type rdf:resource="http://example.org/ontology/bookrec#Theme"/>
        <rdfs:label>Fantasy</rdfs:label>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/ontology/bookrec#Mystery">
        <rdf:type rdf:resource="http://example.org/ontology/bookrec#Theme"/>
        <rdfs:label>Mystery</rdfs:label>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/ontology/bookrec#Murder">
        <rdf:type rdf:resource="http://example.org/ontology/bookrec#Theme"/>
        <rdfs:label>Murder</rdfs:label>
    </owl:NamedIndividual>

    <!-- INDIVIDUALS: READING LEVELS -->
    <owl:NamedIndividual rdf:about="http://example.org/ontology/bookrec#Beginner">
        <rdf:type rdf:resource="http://example.org/ontology/bookrec#ReadingLevel"/>
        <rdfs:label>Beginner</rdfs:label>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/ontology/bookrec#Intermediate">
        <rdf:type rdf:resource="http://example.org/ontology/bookrec#ReadingLevel"/>
        <rdfs:label>Intermediate</rdfs:label>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/ontology/bookrec#Advanced">
        <rdf:type rdf:resource="http://example.org/ontology/bookrec#ReadingLevel"/>
        <rdfs:label>Advanced</rdfs:label>
    </owl:NamedIndividual>

    <!-- INDIVIDUALS: BOOKS -->
    <owl:NamedIndividual rdf:about="http://example.org/ontology/bookrec#Dune">
        <rdf:type rdf:resource="http://example.org/ontology/bookrec#Book"/>
        <rdfs:label>Dune</rdfs:label>
        <bookrec:hasTitle>Dune</bookrec:hasTitle>
        <bookrec:hasAuthor>Frank Herbert</bookrec:hasAuthor>
        <bookrec:hasTheme rdf:resource="http://example.org/ontology/bookrec#ScienceFiction"/>
        <bookrec:hasTheme rdf:resource="http://example.org/ontology/bookrec#Fantasy"/>
        <bookrec:hasReadingLevel rdf:resource="http://example.org/ontology/bookrec#Advanced"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/ontology/bookrec#TheSilentPatient">
        <rdf:type rdf:resource="http://example.org/ontology/bookrec#Book"/>
        <rdfs:label>The Silent Patient</rdfs:label>
        <bookrec:hasTitle>The Silent Patient</bookrec:hasTitle>
        <bookrec:hasAuthor>Alex Michaelides</bookrec:hasAuthor>
        <bookrec:hasTheme rdf:resource="http://example.org/ontology/bookrec#Mystery"/>
        <bookrec:hasTheme rdf:resource="http://example.org/ontology/bookrec#Murder"/>
        <bookrec:hasReadingLevel rdf:resource="http://example.org/ontology/bookrec#Intermediate"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/ontology/bookrec#HungerGames">
        <rdf:type rdf:resource="http://example.org/ontology/bookrec#Book"/>
        <rdfs:label>Hunger Games</rdfs:label>
        <bookrec:hasTitle>Hunger Games</bookrec:hasTitle>
        <bookrec:hasAuthor>Suzanne Collins</bookrec:hasAuthor>
        <bookrec:hasTheme rdf:resource="http://example.org/ontology/bookrec#ScienceFiction"/>
        <bookrec:hasTheme rdf:resource="http://example.org/ontology/bookrec#Fantasy"/>
        <bookrec:hasReadingLevel rdf:resource="http://example.org/ontology/bookrec#Beginner"/>
    </owl:NamedIndividual>

    <!-- INDIVIDUALS: USERS -->
    <owl:NamedIndividual rdf:about="http://example.org/ontology/bookrec#Alice">
        <rdf:type rdf:resource="http://example.org/ontology/bookrec#User"/>
        <rdfs:label>Alice</rdfs:label>
        <bookrec:hasName>Alice</bookrec:hasName>
        <bookrec:userHasReadingLevel rdf:resource="http://example.org/ontology/bookrec#Intermediate"/>
        <bookrec:prefersTheme rdf:resource="http://example.org/ontology/bookrec#ScienceFiction"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/ontology/bookrec#Bob">
        <rdf:type rdf:resource="http://example.org/ontology/bookrec#User"/>
        <rdfs:label>Bob</rdfs:label>
        <bookrec:hasName>Bob</bookrec:hasName>
        <bookrec:userHasReadingLevel rdf:resource="http://example.org/ontology/bookrec#Beginner"/>
        <bookrec:prefersTheme rdf:resource="http://example.org/ontology/bookrec#Mystery"/>
    </owl:NamedIndividual>

</rdf:RDF>
